# Optional: enable OpenAI-powered letter generation
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Required for admin panel (initial password; can be changed via admin UI)
# After a password change, the hash is stored in app/data/admin_config.json
ADMIN_PASSWORD=change-me-to-a-secure-password

# Production (Render): optional persistent data directory on a mounted disk
# DATA_DIR=/var/data

# Production (Render): extra CORS origins, comma-separated
# CORS_ORIGINS=https://example.com
